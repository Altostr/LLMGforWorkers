{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "api",
  "main": "worker.ts",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "api.altostr.com",
      "custom_domain": true,
      "zone_name": "altostr.com"
    }
  ],
  "compatibility_date": "2026-05-10",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "api"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "altostrapi",
      "database_id": "8257a3ea-5b77-4256-aa42-b7e768873110"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "LOG_QUEUE",
        "queue": "altostrapi"
      }
    ],
    "consumers": [
      {
        "queue": "altostrapi",
        "dead_letter_queue": "altostrapi-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3
      }
    ]
  }
}
