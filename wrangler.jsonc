{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "model-gate",
  "main": "worker.ts",
  "workers_dev": true,
  "preview_urls": true,
  "compatibility_date": "2026-05-10",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "model-gate"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "model-gate",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "LOG_QUEUE",
        "queue": "model-gate-chat-logs"
      }
    ],
    "consumers": [
      {
        "queue": "model-gate-chat-logs",
        "dead_letter_queue": "model-gate-chat-logs-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3
      }
    ]
  }
}
