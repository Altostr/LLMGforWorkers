{
  "name": "model-gate",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "cf:build": "cross-env MODEL_GATE_TARGET=cloudflare opennextjs-cloudflare build",
    "cf:configure": "node scripts/configure-cloudflare.mjs",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "preview": "npm run cf:build && opennextjs-cloudflare preview",
    "deploy": "npm run cf:configure && npm run cf:build && opennextjs-cloudflare deploy",
    "upload": "npm run cf:configure && npm run cf:build && opennextjs-cloudflare upload",
    "cf-typegen": "npm run cf:typegen",
    "d1:create": "wrangler d1 create altostrapi",
    "d1:migrate:local": "wrangler d1 migrations apply altostrapi --local",
    "d1:migrate:remote": "wrangler d1 migrations apply altostrapi --remote",
    "queues:create": "wrangler queues create altostrapi",
    "queues:create:dlq": "wrangler queues create altostrapi-dlq"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@opennextjs/cloudflare": "^1.8.2",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "next": "16.2.5",
    "react": "19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.34.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
